{
  "rewrites": [
    { "source": "/join/:token", "destination": "/join.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "functions": {
    "api/extract.js": {
      "runtime": "edge"
    }
  }
}
